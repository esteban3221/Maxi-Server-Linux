#ifndef VERSION_HPP
#define VERSION_HPP

#include <string>

namespace Maxicajero
{
    class Version
    {
    public:
        static constexpr int MAJOR = @PROJECT_VERSION_MAJOR@;
        static constexpr int MINOR = @PROJECT_VERSION_MINOR@;
        static constexpr int PATCH = @PROJECT_VERSION_PATCH@;
        // Añadimos el número de build (commits)
        static constexpr int BUILD = @PROJECT_VERSION_BUILD@; 
        
        static constexpr const char *STRING = "@PROJECT_VERSION@";
        static constexpr const char *NAME = "@PROJECT_NAME@";
        static constexpr const char *DESCRIPTION = "@PROJECT_DESCRIPTION@";

        static std::string getFullVersion()
        {
            // Retorna algo como: "Maxicajero Server Local v2.0.0+145"
            return std::string(NAME) + " v" + STRING + "+" + std::to_string(BUILD);
        }

        static std::string getVersion() { return STRING; }
        static int getBuild() { return BUILD; }
        // ... resto de tus métodos igual
    };
}

#endif // VERSION_HPP